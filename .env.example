PROVIDER=openai

# ---------- 默认：本机 Ollama（OpenAI 兼容，无云 API 费用）----------
# 默认与代码一致：若未设置 OPENAI_API_BASE，则等价于 http://127.0.0.1:11434/v1
OPENAI_API_BASE=http://127.0.0.1:11434/v1
OPENAI_MODEL=llama3.2:latest
# 本机可不填；留空时会使用 OPENAI_LOCAL_PLACEHOLDER_KEY（默认 ollama）
OPENAI_API_KEY=

# 单次 HTTP 超时（秒）；不设时本机默认 600、云上默认 120
LLM_API_TIMEOUT_SECONDS=600

# ---------- 可选：改回 OpenAI 云端 ----------
# OPENAI_API_BASE=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-...

# ---------- 可选第二模型（答题阶段，见 ENABLE_DEEPSEEK_IN_ANSWERING）----------
ENABLE_DEEPSEEK_IN_ANSWERING=0
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_API_BASE=https://api.deepseek.com/v1

TAVILY_API_KEY=
GOOGLE_API_KEY=
GOOGLE_CX=

TESS_LANG=chi_sim+eng
EMBED_BATCH=64
HTTP_TIMEOUT_CONNECT=6
HTTP_TIMEOUT_READ=18
