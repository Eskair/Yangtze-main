PROVIDER=openai

# ---------- 默认：本机 Ollama（OpenAI 兼容，无云 API 费用）----------
# 默认与代码一致：若未设置 OPENAI_API_BASE，则等价于 http://127.0.0.1:11434/v1
OPENAI_API_BASE=http://127.0.0.1:11434/v1
OPENAI_MODEL=llama3.2:latest
# 本机可不填；留空时会使用 OPENAI_LOCAL_PLACEHOLDER_KEY（默认 ollama）
OPENAI_API_KEY=

# 单次 HTTP 超时（秒）；不设时本机默认 600、云上默认 120
LLM_API_TIMEOUT_SECONDS=600

# ---------- 可选：改回 OpenAI 云端 ----------
# OPENAI_API_BASE=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-...

# ---------- 可选第二模型（答题阶段，见 ENABLE_DEEPSEEK_IN_ANSWERING）----------
ENABLE_DEEPSEEK_IN_ANSWERING=0
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_API_BASE=https://api.deepseek.com/v1

TAVILY_API_KEY=
GOOGLE_API_KEY=
GOOGLE_CX=

TESS_LANG=chi_sim+eng
EMBED_BATCH=64
HTTP_TIMEOUT_CONNECT=6
HTTP_TIMEOUT_READ=18

# ---------- 文本长度与质量闸门（与 src/tools 默认值对齐；可按项目调）----------
# 题干：约 N 字内一整句完整问句为主；程序仅在超长时句读兜底截断（generate_questions / llm_answering）。
MAX_QUESTION_CHARS=60
MAX_PROMPT_QUESTION_CHARS=60

# 答题：每一分点 / claims·evidence_hints·general_insights 每一条上限（字符）；模型自控语义完整为主。
# MAX_REVIEW_CHARS=150
# MAX_ANSWER_CHARS=150

# 汇总报告正文总字数上限（report_limits.py）。
# MAX_AGGREGATED_REPORT_CHARS=2500

# ---------- 专家评审（ai_expert_opinion v5：叙事型 BP 轨 + 双模式）----------
# 专用模型（覆盖 OPENAI_MODEL；叙事长文建议强模型）
# EXPERT_OPINION_MODEL=gpt-4o
# 同义：OPENAI_EXPERT_MODEL=gpt-4o
# 专家 HTTP 读超时（秒，避免云端长文超时；默认已较 HTTP_TIMEOUT_READ 更宽）
# EXPERT_HTTP_TIMEOUT_READ=120
# EXPERT_HTTP_TIMEOUT_CONNECT=30
# 注入 prepared/<pid>/full_text.txt 的最大字符数
# EXPERT_FULLTEXT_MAX_CHARS=28000
# 专家 LLM 最大输出 token（含 bp_review）
# EXPERT_MAX_TOKENS=4200
